{
  "pluginAlias": "NetatmoWeather",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Accessory Name",
        "type": "string",
        "default": "Netatmo Weather"
      },
      "weatherEndpoint": {
        "title": "Weather Endpoint URL",
        "type": "string",
        "placeholder": "http://192.168.1.100:8087/weather",
        "required": true,
        "description": "URL of the netatmo-scanner /weather endpoint"
      },
      "pollInterval": {
        "title": "Poll Interval (minutes)",
        "type": "integer",
        "default": 30,
        "minimum": 5,
        "description": "How often to fetch weather data"
      }
    }
  }
}
